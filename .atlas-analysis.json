  "keyFeatures": [
    "Automated TikTok creator discovery via keyword search",
    "30-day engagement metrics aggregation (views, likes, comments, shares)",
    "Multi-platform support (TikTok, Instagram, Twitter, YouTube)",
    "Real-time analytics dashboard with filtering and sorting",
    "Budget management and API cost tracking",
    "Automated discovery pipeline with job queuing",
    "Data export to CSV and other formats",
    "CLI tools for database and creator management"
  ],
  "publicApiSurface": [
    "TikTokApifyService.getUserProfile(username)",
    "TikTokApifyService.searchProfiles(keywords, limit)",
    "TikTokApifyService.getUserInsights(username)",
    "DiscoveryPipeline.start()",
    "DiscoveryPipeline.processTrendingDiscovery(data)",
    "CreatorEvaluator.evaluateCreator(creatorData)",
    "DataAggregationEngine.aggregateCreatorData(creatorId)",
    "BudgetManager (budget allocation and tracking)",
    "CLI: tiktok-miner creators <subcommand>",
    "CLI: tiktok-miner discovery <subcommand>",
